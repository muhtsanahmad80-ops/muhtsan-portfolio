# ─────────────────────────────────────────────
# Muhtsan Ahmad Portfolio — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Site URL (update to your actual domain)
NEXT_PUBLIC_SITE_URL=https://muhtsanahmad.com

# ── Email (choose one) ──────────────────────

# Option 1: Resend (recommended)
# Get your key at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option 2: Nodemailer / Gmail SMTP
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_TO=contact@muhtsanahmad.com
